# simplefactuapp · desarrollo local
# Copiar: cp .env.example .env.local
# Vercel QA/prod: ver .env.qa.example y .env.prod.example (referencia Bitwarden / panel Vercel).

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_CHANGE_ME
CLERK_SECRET_KEY=sk_test_CHANGE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/invoices
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/invoices

SIMPLEFACTU_API_BASE_URL=http://localhost:3000/v1
SIMPLEFACTU_ADMIN_KEY=dev-admin-key-change-me
VERIFACTU_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
