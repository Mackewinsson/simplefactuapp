# Postgres (e.g. Neon from npx neonctl@latest init)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Clerk (get keys from https://dashboard.clerk.com). Copy to .env.local with real keys only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/invoices
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/invoices

# Clerk webhooks (optional): Dashboard → Webhooks → signing secret for /api/webhooks/clerk
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Verifactu API (simplefactu) — server-only. Base con /v1; define también los `servers`
# del OpenAPI en /docs/api-reference. QA: https://api.qa.simplefactu.com/v1
SIMPLEFACTU_API_BASE_URL=http://localhost:3000/v1
# Opcional: misma URL pública para documentación Scalar si solo expones vars NEXT_PUBLIC en el panel de deploy.
# Si falta SIMPLEFACTU_API_BASE_URL, /api/openapi.json y /docs/api-reference usan este fallback.
# NEXT_PUBLIC_SIMPLEFACTU_API_BASE_URL=https://api.qa.simplefactu.com/v1
# Provisions tenant + API key on first use (never expose to the browser)
SIMPLEFACTU_ADMIN_KEY=your-simplefactu-admin-key
# Comma-separated Clerk user IDs: optional Edge gate for /admin. If set, only these userIds may enter /admin
# (use empty + publicMetadata.role=admin for metadata-only admins). See AGENTS.md / middleware.
# ADMIN_CLERK_USER_IDS=user_xxx,user_yyy
# Timeout for simplefactu admin HTTP from the app (ms)
# SIMPLEFACTU_ADMIN_FETCH_TIMEOUT_MS=30000
# Encrypts stored per-user API keys in Postgres (openssl rand -base64 32)
VERIFACTU_ENCRYPTION_KEY=

# Optional overrides for SistemaInformatico block (defaults: nombre = issuer legal name, nif = issuer NIF)
# VERIFACTU_SI_NOMBRE_RAZON=
# VERIFACTU_SI_NIF=
# VERIFACTU_SI_NOMBRE=SimpleFactuApp
# VERIFACTU_SI_ID=01
# VERIFACTU_SI_VERSION=1.0.0
# VERIFACTU_SI_SOLO_VERI=S
# VERIFACTU_SI_MULTI_OT=N
# VERIFACTU_SI_IND_MULTI_OT=N
# Deprecated: QR y «Comprobar en AEAT» usan aeatQrText de la API (qrInfo.qrText).
# VERIFACTU_VERIFY_QR_BASE=https://prewww2.aeat.es/wlpl/TIKE-CONT/ValidarQR

# --- Producción ---
# NODE_ENV=production (la define el host: Vercel, Docker, etc.)
# SIMPLEFACTU_API_BASE_URL=https://api.tudominio.com/v1
# Clerk: instancia de producción, dominios autorizados y URLs públicas al dominio real
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# Tras despliegue: pnpm prisma:migrate:deploy (o migrate en CI antes del tráfico)
# Docker: ver Dockerfile (standalone). Ej.: docker build -t app . && docker run -p 3000:3000 --env-file .env.production app
