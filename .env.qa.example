# simplefactuapp · Vercel Preview (rama develop → qa.simplefactu.com)
# Pegar en Vercel → Environment Variables → Preview, o backup Bitwarden.
# SIMPLEFACTU_ADMIN_KEY = ADMIN_KEY del VPS QA (deploy/.env.qa.example en el servidor).

DATABASE_URL=postgresql://USER:PASSWORD@HOST-NEON-QA/neondb?sslmode=require

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_CHANGE_ME
CLERK_SECRET_KEY=sk_test_CHANGE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/invoices
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/invoices

SIMPLEFACTU_API_BASE_URL=https://api.qa.simplefactu.com/v1
NEXT_PUBLIC_SIMPLEFACTU_API_BASE_URL=https://api.qa.simplefactu.com/v1
SIMPLEFACTU_ADMIN_KEY=CHANGE_ME_SAME_AS_VPS_QA_ADMIN_KEY
VERIFACTU_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES_QA_ONLY

NEXT_PUBLIC_BILLING_ENABLED=false
