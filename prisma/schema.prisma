// Postgres (Neon for production; use Neon dev branch or local Postgres for dev).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AeatJobStatus {
  NOT_SENT
  PENDING
  SUCCEEDED
  FAILED
  DEAD
}

enum AeatCancellationStatus {
  NONE
  PENDING
  SUCCEEDED
  FAILED
  DEAD
}

/// Clerk userId ↔ simplefactu tenant + encrypted API key (BFF only).
model UserVerifactuAccount {
  userId                String    @id
  simplefactuTenantId   String
  apiKeyEncrypted       String    @db.Text
  issuerNif             String?
  issuerLegalName       String?
  certificateUploadedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("user_verifactu_accounts")
}

model Invoice {
  id                 String        @id @default(cuid())
  userId             String
  number             String
  issueDate          DateTime
  dueDate            DateTime?
  fechaOperacion     DateTime?
  customerName       String
  customerEmail      String?
  customerNif        String?
  customerTipoPersona String?
  /// NIF | ID_OTRO — destinatario AEAT
  customerIdScheme   String        @default("NIF")
  /// Códigos AEAT IDType (02 NIF-IVA, 03 Pasaporte, etc.) cuando customerIdScheme = ID_OTRO
  customerIdType     String?
  customerCodigoPais String?
  customerForeignId  String?
  currency           String        @default("EUR")
  subtotalCents      Int
  taxCents           Int
  totalCents         Int
  taxRatePercent     Int           @default(21)
  notes              String?
  createdByFirstName String?
  createdByLastName  String?
  aeatStatus         AeatJobStatus @default(NOT_SENT)
  aeatJobId          String?
  aeatLastError      String?
  aeatCsv            String?
  aeatQrText         String?
  aeatIdempotencyKey String?       @unique
  aeatCancellationJobId     String?
  aeatCancellationStatus    AeatCancellationStatus @default(NONE)
  aeatCancellationLastError String?
  aeatCancellationIdempotencyKey String? @unique
  aeatUpdatedAt      DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  items              InvoiceItem[]

  @@index([userId])
  @@unique([userId, number])
}

model InvoiceItem {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description    String
  quantity       Int
  unitPriceCents Int
  discountCents  Int      @default(0)
  discountConcept String?
  lineTotalCents Int
  claveRegimen   String   @default("01")
  calificacion   String   @default("S1")
  tipoImpositivo String   @default("21.0")
}

model Customer {
  id          String   @id @default(cuid())
  userId      String
  name        String
  nif         String?
  email       String?
  tipoPersona String?
  idScheme    String   @default("NIF")
  idType      String?
  codigoPais  String?
  foreignId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Product {
  id             String   @id @default(cuid())
  userId         String
  description    String
  unitPriceCents Int
  tipoImpositivo String   @default("21.0")
  claveRegimen   String   @default("01")
  calificacion   String   @default("S1")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}
